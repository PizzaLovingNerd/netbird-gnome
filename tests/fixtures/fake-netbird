#!/usr/bin/env bash
set -euo pipefail

command="${1:-}"
shift || true

case "${command}" in
    up)
        if [[ "${NETBIRD_FAKE_LOGIN:-}" == "1" ]]; then
            echo "Please do the SSO login in your browser."
            echo "If your browser didn't open automatically, use this URL to log in:"
            echo "https://login.example.test/device?user_code=NETBIRD"
            exit 1
        fi

        echo "Daemon status: Connected"
        ;;
    down)
        echo "Disconnected"
        ;;
    status)
        if [[ -n "${NETBIRD_FAKE_STATUS_JSON:-}" ]]; then
            echo "${NETBIRD_FAKE_STATUS_JSON}"
            exit 0
        fi

        echo '{"daemonStatus":"Connected","netbirdIp":"100.64.0.1/32","profileName":"default"}'
        ;;
    profile)
        subcommand="${1:-}"
        shift || true
        case "${subcommand}" in
            list)
                printf 'Found 2 profiles:\n'
                printf '✓ default\n'
                printf '✗ Work Profile\n'
                ;;
            add)
                echo "Profile added successfully: ${1:-}"
                ;;
            remove)
                echo "Profile removed successfully: ${1:-}"
                ;;
            select)
                echo "Profile switched successfully to: ${1:-}"
                ;;
            *)
                echo "unknown profile command: ${subcommand}" >&2
                exit 2
                ;;
        esac
        ;;
    *)
        echo "unknown netbird command: ${command}" >&2
        exit 2
        ;;
esac
